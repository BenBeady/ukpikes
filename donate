<div class="page-title">
  <h1>Donate</h1>
  <p>Support the brothers, the chapter, and the future of Pi Kappa Alpha at the University of Kentucky.</p>
</div>

<!-- CTA HERO -->
<section class="section section-dark">
  <div style="text-align:center;">
    <p class="section-label" style="color:var(--gold-vivid);">Support Omega Chapter</p>
    <h2 style="font-size:2.2rem;margin-bottom:12px;">Invest in the Brotherhood</h2>
    <p style="color:rgba(255,255,255,.72);max-width:580px;margin:0 auto 28px;">
      Your gift supports scholarships, philanthropy events, the housing campaign, and day-to-day operations that make Pike one of the strongest chapters at UK.
    </p>
    <a href="https://supportmychapter.funraise.org/team/omega-kentucky" target="_blank" class="btn btn-gold">Give Now at fundraise →</a>
  </div>
</section>

<!-- WHERE IT GOES -->
<section class="section">
  <p class="section-label">Impact</p>
  <h2>Where Your Gift Goes</h2>
  <div class="card-grid card-grid-4">
    <div class="card">
      <div class="card-header">Scholarships</div>
      <div class="card-body">
        <ul>
          <li>Academic awards for high-GPA brothers</li>
          <li>GPA incentive programs</li>
          <li>Study support resources</li>
          <li>National Pike Foundation scholarships</li>
        </ul>
      </div>
    </div>
    <div class="card">
      <div class="card-header">Philanthropy</div>
      <div class="card-body">
        <ul>
          <li>Annual charity event funding</li>
          <li>Partner organization donations</li>
          <li>Community service programs</li>
          <li>National Fireman's Challenge</li>
        </ul>
      </div>
    </div>
    <div class="card">
      <div class="card-header gold">Housing Fund</div>
      <div class="card-body">
        <ul>
          <li>New chapter house at UK</li>
          <li>Facility planning and development</li>
          <li>Long-term 501(c)(3) investment</li>
          <li>Legacy gift for future brothers</li>
        </ul>
      </div>
    </div>
    <div class="card">
      <div class="card-header">Operations</div>
      <div class="card-body">
        <ul>
          <li>Chapter programs and events</li>
          <li>Recruitment tools and materials</li>
          <li>Leadership development programs</li>
          <li>Pike University participation</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- FUNRAISE EMBED -->
<section class="section section-alt">
  <p class="section-label">Donation Portal</p>
  <h2>Give Online via Funraise</h2>
  <div class="funraise-box">
    <h3>[ Funraise Donation Widget ]</h3>
    <p>
      The Funraise embedded donation form will appear here. This is managed by Jeff Ashley of Pike National and is tied directly to the Omega Chapter 501(c)(3). Supports one-time and recurring gifts — mobile-friendly with secure payment processing.
    </p>
    <a href="https://supportmychapter.funraise.org/team/omega-kentucky" target="_blank" class="btn btn-garnet">Give at supportmychapter.funraise.org →</a>
    <p style="margin-top:16px;font-size:.8rem;color:#888;">For embedding assistance, contact Jeff Ashley — Jeff@pikefoundation.org</p>
  </div>
</section>

<!-- WAYS TO GIVE -->
<section class="section">
  <p class="section-label">Options</p>
  <h2>Ways to Give</h2>
  <div class="card-grid card-grid-3">
    <div class="card">
      <div class="card-header">Online</div>
      <div class="card-body">
        <h3>Give via Funraise</h3>
        <p>The easiest way to give. Credit card, debit card, or ACH bank transfer. Instant receipt emailed to you.</p>
        <br><a href="https://supportmychapter.funraise.org" target="_blank" class="btn btn-garnet" style="padding:9px 18px;font-size:.78rem;">Donate Online →</a>
      </div>
    </div>
    <div class="card">
      <div class="card-header">Pledge</div>
      <div class="card-body">
        <h3>Multi-Year Commitment</h3>
        <p>Spread your gift over multiple years on a schedule that works for you. Contact our alumni team to set up a pledge agreement.</p>
        <br><a href="mailto:alumni@ukpikes.com" class="btn btn-garnet" style="padding:9px 18px;font-size:.78rem;">Set Up a Pledge →</a>
      </div>
    </div>
    <div class="card">
      <div class="card-header gold">Check / Wire</div>
      <div class="card-body">
        <h3>Traditional Gift</h3>
        <p>Make checks payable to <em>Pi Kappa Alpha — Omega Chapter</em>. Contact us for mailing address and wire transfer details.</p>
        <br><a href="mailto:alumni@ukpikes.com" class="btn btn-gold" style="padding:9px 18px;font-size:.78rem;">Get Details →</a>
      </div>
    </div>
  </div>
</section>

